# ============================================
# DEPENDENCIES
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# ENVIRONMENT VARIABLES (Contains secrets!)
# ============================================
.env
.env.local
.env.production
.env.development

# ============================================
# USER UPLOADS (Media files)
# ============================================
uploads/
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.avi
*.mov
*.mp3
*.wav
*.pdf
*.doc
*.docx

# ============================================
# DATABASE (Local MongoDB files)
# ============================================
data/
*.db
*.sqlite
*.sqlite3

# ============================================
# LOGS
# ============================================
logs/
*.log

# ============================================
# OS FILES
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# IDE FILES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.tmp

# ============================================
# BUILD FILES
# ============================================
dist/
build/
*.tsbuildinfo

# ============================================
# TEMPORARY FILES
# ============================================
*.temp
*.tmp
*.cache

# ============================================
# TEST COVERAGE
# ============================================
coverage/
.nyc_output/

# ============================================
# NPM / YARN
# ============================================
package-lock.json
yarn.lock

# ============================================
# TWILIO / SECRETS (Never commit these!)
# ============================================
# .env.example is allowed (with placeholder values)
# But never commit actual .env files