# ============================================
# DATABASE - MongoDB Connection
# ============================================
# Local development (default):
MONGO_URI=mongodb://localhost:27017/whatsapp-clone

# Production (MongoDB Atlas) - Uncomment and fill:
# Format: mongodb+srv://<db_username>:<db_password>@<cluster>.mongodb.net/<db_name>?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/whatsapp-clone?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION - For user sessions
# ============================================
# Generate a random string (minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ============================================
# SERVER
# ============================================
PORT=5000

# ============================================
# CORS - Frontend URL
# ============================================
# Development:
CLIENT_URL=http://localhost:5173

# Production (uncomment when deploying):
# CLIENT_URL=https://your-app-name.vercel.app

# ============================================
# TWILIO - OTP via SMS (Verify Service)
# ============================================
# Get these from: https://console.twilio.com
# Account SID: Starts with "AC"
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here

# Auth Token: Your Twilio auth token
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Verify Service SID: Starts with "VA"
# Create a Verify Service in Twilio Console → Verify → Services
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# WhatsApp Sandbox Number (optional - only if using WhatsApp channel):
TWILIO_WHATSAPP_NUMBER=+14155238886

# For production WhatsApp Business number:
# TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX

# ============================================
# CLOUDINARY - File Uploads (Optional)
# ============================================
# Sign up at: https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret